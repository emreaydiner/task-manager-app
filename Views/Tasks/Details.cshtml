@model TaskManagerApp.Models.TaskItem

@{
    ViewData["Title"] = "Task Details";
}

<h1>Task Details</h1>

<div class="mt-4">
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">
            @if (Model.Status == "Done")
            {
                <span class="badge bg-success">@Model.Status</span>
            }
            else if (Model.Status == "In Progress")
            {
                <span class="badge bg-warning text-dark">@Model.Status</span>
            }
            else
            {
                <span class="badge bg-secondary">@Model.Status</span>
            }
        </dd>

        <dt class="col-sm-2">Due Date</dt>
        <dd class="col-sm-10">@Model.DueDate?.ToString("yyyy-MM-dd")</dd>

        <dt class="col-sm-2">Created At</dt>
        <dd class="col-sm-10">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    </dl>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <span class="me-1">←</span> Back to List
    </a>
</div>