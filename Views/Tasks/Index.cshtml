@model IEnumerable<TaskManagerApp.Models.TaskItem>

@{
    ViewData["Title"] = "Tasks";
}

<h1 class="mb-4">Task List</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Create New Task</a>
</p>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Status</th>
            <th>Due Date</th>
            <th>Created At</th>
            <th style="width: 220px;">Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Title</td>
            <td>@item.Description</td>
            <td>
                @if (item.Status == "Done")
                {
                    <span class="badge bg-success">@item.Status</span>
                }
                else if (item.Status == "In Progress")
                {
                    <span class="badge bg-warning text-dark">@item.Status</span>
                }
                else
                {
                    <span class="badge bg-secondary">@item.Status</span>
                }
            </td>
            <td>@item.DueDate?.ToString("yyyy-MM-dd")</td>
            <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>