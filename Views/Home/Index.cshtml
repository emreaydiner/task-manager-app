@{
    ViewData["Title"] = "Home";
}

<div class="text-center mt-5">
    <h1 class="display-4">Task Manager App</h1>
    <p class="lead mt-3">
        A simple task management web application built with ASP.NET Core MVC, Entity Framework Core, and SQLite.
    </p>
    <p>
        Users can create, view, edit, and delete tasks while tracking status and due dates.
    </p>

    <a class="btn btn-primary btn-lg mt-3" asp-controller="Tasks" asp-action="Index">View Tasks</a>
</div>
